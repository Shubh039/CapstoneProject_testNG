<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="ParaBank Positive Testing Suite" verbose="1">

	<listeners>
        <listener class-name="utilities.TestListener"/>
    </listeners>
    
    <test name="POSITIVE TEST CASES">
        <classes>
            <class name="testcases.RegistrationTest"/>
            <class name="testcases.LoginTest"/>
            <class name="testcases.OpenAccountTest"/>
            <class name="testcases.TransferFundsTest"/>
            <class name="testcases.BillPaymentTest"/>
            <class name="testcases.RequestLoanTest"/>
        </classes>
    </test>
    
    <test name="NEGATIVE TEST CASES">
        <classes>
            <class name="testcases.NegativeTest"/>
        </classes>
    </test>
    
</suite>