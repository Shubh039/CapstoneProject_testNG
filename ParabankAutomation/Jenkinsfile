pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {
        stage('Checkout') {
            steps {
                echo '======== Checking out source code ========'
                git branch: 'master',
                    url: 'https://github.com/Shubh039/CapstoneProject_testNG'
                echo '✅ Code pulled from GitHub'
            }
        }
        
        stage('Start Parabank') {
            steps {
                echo '======== Starting Parabank in Docker ========'
                bat '''
                    docker stop parabank 2>nul || echo No old container
                    docker rm parabank 2>nul || echo No old container
                    docker pull parasoft/parabank
                    docker run -d --name parabank -p 8081:8080 parasoft/parabank
                    ping -n 41 127.0.0.1 > nul
                    echo Parabank ready on port 8081
                '''
                echo '✅ Parabank running in Docker'
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo '======== Building Automation Docker Image ========'
                dir('ParabankAutomation') {
                    bat 'docker build -t parabank-automation .'
                }
                echo '✅ Docker image built successfully'
            }
        }

        stage('Run Tests') {
            steps {
                echo '======== Running All Test Suites in Docker ========'
                echo 'Order: Smoke → Regression → Negative'
                dir('ParabankAutomation') {
                    bat '''
                        docker run --rm ^
                          -e headless=true ^
                          --add-host=host.docker.internal:host-gateway ^
                          -v %CD%/reports:/app/reports ^
                          -v %CD%/screenshots:/app/screenshots ^
                          -v %CD%/logs:/app/logs ^
                          -v %CD%/target:/app/target ^
                          parabank-automation
                    '''
                }
                echo '✅ Tests completed inside Docker'
            }
        }


        stage('Archive Reports') {
            steps {
                echo '======== Archiving Reports ========'
                archiveArtifacts artifacts: 'ParabankAutomation/reports/**/*',
                                 allowEmptyArchive: true
                archiveArtifacts artifacts: 'ParabankAutomation/screenshots/**/*',
                                 allowEmptyArchive: true
                archiveArtifacts artifacts: 'ParabankAutomation/logs/**/*',
                                 allowEmptyArchive: true
                echo '✅ Reports archived'
            }
    	}
	}
    
	post {
        always {
            echo '======== Cleanup ========'
            bat '''
                docker stop parabank 2>nul || echo Already stopped
                docker rm parabank 2>nul || echo Already removed
                echo Cleanup done
            '''
            junit allowEmptyResults: true,
                  testResults: 'ParabankAutomation/**/target/surefire-reports/*.xml'
        }
        success {
            echo '╔══════════════════════════════════════╗'
            echo '║   ✅ ALL SUITES PASSED               ║'
            echo '║   Smoke + Regression + Negative      ║'
            echo '╚══════════════════════════════════════╝'
        }
        failure {
            echo '╔══════════════════════════════════════╗'
            echo '║   ❌ BUILD FAILED                    ║'
            echo '║   Check Console Output for details   ║'
            echo '╚══════════════════════════════════════╝'
        }
	}
}
